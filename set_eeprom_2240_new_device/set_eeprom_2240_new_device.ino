int i;

void setup()
{
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n\nAnd so it begins");
  Serial.println(__FILE__);
  Serial.print(__TIME__);
  Serial.print(F(" "));
  Serial.println(__DATE__);

  EEPROM.begin(256);

  // use first four bytes of MAC address as serial number
  for (int i=0; i<4; i++)
  {
    eepromdata[0x0C+i]=hexcharstobyte(WiFi.macAddress()[3*i], WiFi.macAddress()[3*i+1]);
  }

  // mask high bit of first byte to ensure serial number appears positive in UPStart
  eepromdata[0x0C] = eepromdata[0x0C] & 0x7F;

  eepromdata[1]=254; // can be changed and checksum will be correctly calculated
  // save as separate file though!

  Serial.printf("Device ID set to %d (0x%02X)\n",eepromdata[1],eepromdata[1]);

  for (int i=0; i<0xFF; i++)
  {
    EEPROM.write(i,eepromdata[i]);
  }

  Serial.printf("Checksum %02X\n",geteepromchecksum());

  seteepromchecksum();

  EEPROM.commit();
  Serial.println("Written");
}

